# --- Local development ---
DATABASE_URL="file:./dev.db"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Do not set ENFORCE_HTTPS locally — breaks http://localhost (HSTS redirect loop).

ADMIN_EMAIL="admin@local.dev"
ADMIN_PASSWORD="change-me"
FOUNDER_EMAIL="founder@local.dev"
FOUNDER_PASSWORD="change-me"
EVALUATOR_EMAIL="evaluator@local.dev"
EVALUATOR_PASSWORD="change-me"

# --- Production (behind TLS reverse proxy: deploy/Caddyfile or deploy/nginx.conf) ---
# Proxy must send: X-Forwarded-Proto: https, X-Forwarded-Host: <your-domain>
#
# AUTH_URL="https://your-domain.example"
# ENFORCE_HTTPS="true"
# DATABASE_URL="file:./prod.db"
# AUTH_SECRET="<openssl rand -base64 32>"
