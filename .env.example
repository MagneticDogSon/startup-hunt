# --- Database (Supabase Postgres) ---
# Project Settings → Database → Connection string
# App runtime (pooler, port 6543, Transaction mode):
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations / prisma migrate (direct, port 5432):
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# --- Supabase Storage (private bucket `startup-files`) ---
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# SUPABASE_STORAGE_BUCKET="startup-files"

# --- Auth ---
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Do not set ENFORCE_HTTPS locally — breaks http://localhost (HSTS redirect loop).

ADMIN_EMAIL="admin@local.dev"
ADMIN_PASSWORD="change-me"
FOUNDER_EMAIL="founder@local.dev"
FOUNDER_PASSWORD="change-me"
EVALUATOR_EMAIL="evaluator@local.dev"
EVALUATOR_PASSWORD="change-me"

# --- Local dev without Supabase Storage ---
# Omit SUPABASE_* to store uploads in ./uploads/ (Postgres still required).

# --- Production (Vercel) ---
# AUTH_URL="https://your-app.vercel.app"
# ENFORCE_HTTPS="true"
